# ══════════════════════════════════════════════════════════════════════════════
#  .env.example — Copy to .env and fill in ALL values before deploying
#  cp .env.example .env
# ══════════════════════════════════════════════════════════════════════════════

# ── Django core ───────────────────────────────────────────────────────────────
SECRET_KEY=your-very-long-random-secret-key-min-50-chars-change-this
DEBUG=False
ALLOWED_HOSTS=asilbekabdurahmonov.uz,www.asilbekabdurahmonov.uz,127.0.0.1,localhost
CSRF_TRUSTED_ORIGINS=https://asilbekabdurahmonov.uz,https://www.asilbekabdurahmonov.uz

# ── Database ──────────────────────────────────────────────────────────────────
# Path inside the container (must match the Docker volume mount)
DB_PATH=/app/data/db.sqlite3

# ── AI Integration ────────────────────────────────────────────────────────────
GROQ_API_KEY=your-groq-api-key-here

# ── Gunicorn tuning ───────────────────────────────────────────────────────────
GUNICORN_WORKERS=4
GUNICORN_TIMEOUT=60

# ── Domains ───────────────────────────────────────────────────────────────────
DOMAIN_NAME=asilbekabdurahmonov.uz
LOG_DOMAIN=logs.asilbekabdurahmonov.uz

# ── Docker image ──────────────────────────────────────────────────────────────
# Replace <your-github-user> with your actual GitHub username
IMAGE_NAME=ghcr.io/your-github-user/editorial:latest

# ── Dozzle monitoring credentials (generated by setup-server.sh) ─────────────
# DO NOT fill these manually — setup-server.sh generates and writes them
DOZZLE_USERNAME=
DOZZLE_PASSWORD=
